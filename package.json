{
    "name": "@cognizant-ai-lab/neuro-san-ui",
    "version": "1.0.0",
    "private": true,
    "description": "The root package for the Neuro-SAN UI monorepo, containing the MAA UI web app and common components.",
    "license": "Apache-2.0",
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build:app": "yarn workspace @cognizant-ai-lab/neuro-san-web build",
        "build:lib": "yarn workspace @cognizant-ai-lab/ui-common build",
        "build:docker": "docker build -f apps/main/Dockerfile -t neuro-san-ui .",
        "check-format": "yarn prettier --check --log-level warn .",
        "clean": "rm -rf dist generated",
        "commit-check": "./build_scripts/CommitCheck.sh",
        "dev": "yarn workspace @cognizant-ai-lab/neuro-san-web run dev",
        "generate": "rm -rf packages/ui-common/generated && cd packages/ui-common && ./build_scripts/do_openapi_generate.sh",
        "lint": "eslint",
        "lint-rules": "./build_scripts/eslint_list_rules.sh",
        "lint-summary": "eslint --format summary",
        "start": "yarn workspace @cognizant-ai-lab/neuro-san-web start",
        "test": "NODE_OPTIONS=\"--localstorage-file=$(mktemp --directory)/node-storage\" vitest run",
        "update-coverage": "./build_scripts/UpdateCoverage.sh"
    },
    "packageManager": "yarn@4.12.0",
    "engines": {
        "node": "^22.0.0 || ^26.0.0"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@next/eslint-plugin-next": "16.2.10",
        "@testing-library/jest-dom": "6.9.1",
        "@types/dom-speech-recognition": "0.0.12",
        "@types/node": "catalog:default",
        "@types/react": "catalog:default",
        "@vitest/coverage-istanbul": "4.1.10",
        "@vitest/eslint-plugin": "1.6.22",
        "@vitest/utils": "catalog:default",
        "eslint": "catalog:default",
        "eslint-config-prettier": "10.1.8",
        "eslint-formatter-summary": "2.0.2",
        "eslint-import-resolver-typescript": "4.4.5",
        "eslint-plugin-import-x": "4.17.1",
        "eslint-plugin-jest-dom-ya": "1.0.1",
        "eslint-plugin-prefer-arrow-functions": "3.10.1",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-testing-library": "7.16.2",
        "eslint-plugin-unicorn": "65.0.1",
        "fake-indexeddb": "catalog:default",
        "globals": "catalog:default",
        "jsdom": "29.1.1",
        "knip": "6.25.0",
        "prettier": "3.9.4",
        "react": "catalog:default",
        "typescript": "catalog:default",
        "typescript-eslint": "8.63.0",
        "vite": "catalog:default",
        "vitest": "catalog:default",
        "vitest-fail-on-console": "catalog:default"
    },
    "resolutions": {
        "js-yaml": "4.1.1"
    }
}
