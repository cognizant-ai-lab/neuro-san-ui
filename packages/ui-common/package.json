{
    "name": "@cognizant-ai-lab/ui-common",
    "description": "A shared UI component library for Cognizant AI Labs projects",
    "version": "1.2.4",
    "type": "module",
    "scripts": {
        "build": "yarn clean && yarn generate && yarn run --top-level tsc --project tsconfig.build.json && fix-esm-import-path dist > /dev/null",
        "clean": "rm -rf dist generated",
        "generate": "rm -rf generated && ./build_scripts/do_openapi_generate.sh",
        "prepack": "echo PREPACK_RUNNING && yarn build"
    },
    "dependencies": {
        "@dagrejs/dagre": "1.0.4",
        "@langchain/core": "catalog:default",
        "@xyflow/react": "12.10.1",
        "http-status": "catalog:default",
        "jsonrepair": "3.8.0",
        "lodash-es": "catalog:default",
        "notistack": "catalog:default",
        "react-markdown": "catalog:default",
        "react-syntax-highlighter": "16.1.0",
        "rehype-raw": "catalog:default",
        "rehype-slug": "catalog:default",
        "uuid": "11.1.0",
        "zustand": "4.5.7"
    },
    "devDependencies": {
        "@babel/core": "catalog:default",
        "@babel/preset-env": "catalog:default",
        "@testing-library/dom": "catalog:default",
        "@testing-library/react": "catalog:default",
        "@testing-library/user-event": "catalog:default",
        "@types/lodash-es": "catalog:default",
        "@types/node": "catalog:default",
        "@types/react": "catalog:default",
        "@types/react-dom": "catalog:default",
        "@types/react-syntax-highlighter": "15.5.13",
        "babel-jest": "catalog:default",
        "fake-indexeddb": "catalog:default",
        "fix-esm-import-path": "1.10.3",
        "globals": "catalog:default",
        "openapi-typescript": "7.8.0",
        "react": "catalog:default",
        "react-dom": "catalog:default",
        "typescript": "catalog:default"
    },
    "peerDependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.1",
        "@mui/material": "^7.3.1",
        "@mui/x-tree-view": "^8.22.0",
        "next": "^16.2.1",
        "next-auth": "5.0.0-beta.30",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "typescript": "^5.9.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cognizant-ai-lab/neuro-san-ui.git"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./const": "./const.ts"
    },
    "files": [
        "dist"
    ]
}
