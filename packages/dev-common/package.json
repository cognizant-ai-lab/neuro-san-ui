{
    "name": "@cognizant-ai-lab/dev-common",
    "description": "Common development configurations and utilities for Cognizant AI Labs UI projects",
    "version": "1.0.0",
    "type": "module",
    "peerDependencies": {
        "@eslint/compat": "*",
        "@eslint/js": "*",
        "@next/eslint-plugin-next": "*",
        "@testing-library/dom": "*",
        "eslint": "*",
        "eslint-config-prettier": "*",
        "eslint-plugin-import-x": "*",
        "eslint-plugin-jest": "*",
        "eslint-plugin-jest-dom": "*",
        "eslint-plugin-prefer-arrow-functions": "*",
        "eslint-plugin-react": "*",
        "eslint-plugin-react-hooks": "*",
        "eslint-plugin-testing-library": "*",
        "eslint-plugin-unicorn": "*",
        "globals": "*",
        "knip": "*",
        "typescript-eslint": "*"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cognizant-ai-lab/neuro-san-ui.git"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "exports": {
        "./eslint": {
            "types": "./Configs/eslint.config.d.mts",
            "default": "./Configs/eslint.config.mjs"
        },
        "./knip": {
            "types": "./Configs/knip.config.ts",
            "default": "./Configs/knip.config.ts"
        }
    }
}
